{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows Debug (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/Users/renat/Developer/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true
      }
    },
    {
      "name": "windows-visual-studio",
      "displayName": "Visual Studio solution",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}-manifest",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/Users/renat/Developer/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": true,
        "VCPKG_INSTALLED_DIR": "${sourceDir}/out/build/${presetName}-manifest/vcpkg_installed",
        "VE_BUILD_API_DOCS": false,
        "VE_ENABLE_STRICT_WARNINGS": true,
        "VE_WARNINGS_AS_ERRORS": true,
        "VE_USE_LATEST_CXX": true
      }
    },
    {
      "name": "windows-visual-studio-asan",
      "displayName": "Visual Studio ASan",
      "inherits": "windows-visual-studio",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "VE_ENABLE_ASAN": true,
        "VE_BUILD_TESTS": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-build",
      "displayName": "Build voxel engine",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug",
      "targets": ["voxel_engine"]
    },
    {
      "name": "windows-vcpkg-test-build",
      "displayName": "Build voxel engine tests",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug",
      "targets": ["engine_tests"]
    },
    {
      "name": "windows-visual-studio-build",
      "displayName": "Build Visual Studio solution",
      "configurePreset": "windows-visual-studio",
      "configuration": "Debug",
      "targets": ["voxel_engine"]
    },
    {
      "name": "windows-visual-studio-strict",
      "displayName": "Strict Debug: latest C++ and warnings as errors",
      "configurePreset": "windows-visual-studio",
      "configuration": "Debug",
      "targets": ["voxel_engine", "engine_tests"]
    },
    {
      "name": "windows-visual-studio-asan",
      "displayName": "Build with AddressSanitizer",
      "configurePreset": "windows-visual-studio-asan",
      "configuration": "Debug",
      "targets": ["voxel_engine", "engine_tests"]
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-tests",
      "displayName": "Run voxel engine tests",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-visual-studio-asan-tests",
      "displayName": "Run voxel engine tests with AddressSanitizer",
      "configurePreset": "windows-visual-studio-asan",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
